# Veldwatch Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it's in .gitignore.

# --- API ---
VELDWATCH_HOST=0.0.0.0
VELDWATCH_PORT=8000
VELDWATCH_ENV=development
VELDWATCH_LOG_LEVEL=INFO

# --- Database ---
# SQLite (default for development)
VELDWATCH_DB_URL=sqlite:///./veldwatch.db
# PostgreSQL (production)
# VELDWATCH_DB_URL=postgresql://user:password@localhost:5432/veldwatch

# --- Redis ---
VELDWATCH_REDIS_URL=redis://localhost:6379/0

# --- Auth ---
VELDWATCH_SECRET_KEY=change-me-to-a-random-secret
VELDWATCH_JWT_ALGORITHM=HS256
VELDWATCH_JWT_EXPIRY_MINUTES=60

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Alerts ---
# VELDWATCH_SMTP_HOST=smtp.example.com
# VELDWATCH_SMTP_PORT=587
# VELDWATCH_SMTP_USER=
# VELDWATCH_SMTP_PASS=
# VELDWATCH_ALERT_EMAIL=alerts@example.com

# --- Integrations ---
# OPENAI_API_KEY=sk-...
